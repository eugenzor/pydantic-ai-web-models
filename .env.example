# ---------------------------------------------------------------------------
# Temporal connection — read natively by the temporalio SDK via envconfig
# ---------------------------------------------------------------------------

# Server address (host:port).  For Temporal Cloud use <namespace>.tmprl.cloud:7233
TEMPORAL_ADDRESS=localhost:7233

# Namespace.  For Temporal Cloud use <namespace>.<account-id>
TEMPORAL_NAMESPACE=default

# ---------------------------------------------------------------------------
# Authentication — choose ONE of the options below
# ---------------------------------------------------------------------------

# Option A: Temporal Cloud API key
# Generate a key in the Temporal Cloud UI (Settings → API Keys).
# TEMPORAL_API_KEY=

# Option B: mTLS client certificates
# Paths to PEM-encoded files on the local filesystem.
# TEMPORAL_TLS_CERT=/path/to/client.pem        # client certificate
# TEMPORAL_TLS_KEY=/path/to/client.key         # client private key
# TEMPORAL_TLS_CA=/path/to/ca.pem              # CA cert (optional, for custom CA)
# TEMPORAL_TLS_SERVER_NAME=temporal.internal   # override TLS SNI (optional)

# ---------------------------------------------------------------------------
# App-level workflow settings
# ---------------------------------------------------------------------------

# Task queue the Temporal worker listens on
TEMPORAL_TASK_QUEUE=ai-worker-task-queue

# Workflow type name registered on the worker
TEMPORAL_WORKFLOW_NAME=LLMInvokeWorkflow

# Maximum time (seconds) to wait for a workflow to complete
TEMPORAL_TIMEOUT_SECONDS=300
